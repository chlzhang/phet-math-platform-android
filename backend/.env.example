# 后端环境变量示例
# 复制为 .env 后修改

# 数据库
# Docker 部署时 postgres 暴露到主机的端口为 5433，本地直接运行后端时使用该端口
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/phet_math

# Redis
# Docker 部署时 redis 暴露到主机的端口为 6380
REDIS_URL=redis://localhost:6380/0

# 仿真器模板目录（相对项目根目录或绝对路径）
TEMPLATES_DIR=simulators/templates

# LLM 配置（可选，默认 mock）
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_MODEL=
